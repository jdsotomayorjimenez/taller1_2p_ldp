<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/registro_background"
        android:fillViewport="true"
        tools:context=".MainActivity">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="48dp"
            android:paddingEnd="24dp"
            android:paddingBottom="48dp">

        <TextView
                android:id="@+id/txtTituloRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Registro de personas"
                android:textColor="#2F2A35"
                android:textSize="26sp"
                android:textStyle="bold" />

        <LinearLayout
                android:id="@+id/contenedorRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/registro_card_background"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="24dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/lblId"
                        android:layout_width="82dp"
                        android:layout_height="wrap_content"
                        android:text="Id"
                        android:textColor="#665C6B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                <EditText
                        android:id="@+id/txtid"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/registro_input_background"
                        android:hint="Ingrese el id"
                        android:inputType="number"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#2F2A35"
                        android:textColorHint="#9B909E"
                        android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/lblNombre"
                        android:layout_width="82dp"
                        android:layout_height="wrap_content"
                        android:text="Nombre"
                        android:textColor="#665C6B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                <EditText
                        android:id="@+id/txtnombre"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/registro_input_background"
                        android:hint="Ingrese el nombre"
                        android:inputType="textPersonName"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#2F2A35"
                        android:textColorHint="#9B909E"
                        android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/lblApellido"
                        android:layout_width="82dp"
                        android:layout_height="wrap_content"
                        android:text="Apellido"
                        android:textColor="#665C6B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                <EditText
                        android:id="@+id/txtapellido"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/registro_input_background"
                        android:hint="Ingrese el apellido"
                        android:inputType="textPersonName"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#2F2A35"
                        android:textColorHint="#9B909E"
                        android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:orientation="horizontal">

                <Button
                        android:id="@+id/btnguardar"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#4C6584"
                        android:onClick="guardar"
                        android:text="Guardar"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />

                <Button
                        android:id="@+id/btnactualizar"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#4C6584"
                        android:onClick="actualizar"
                        android:text="Actualizar"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                <Button
                        android:id="@+id/btnbuscar"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#4C6584"
                        android:onClick="buscar"
                        android:text="Buscar"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />

                <Button
                        android:id="@+id/btneliminar"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#B94D58"
                        android:onClick="eliminar"
                        android:text="Eliminar"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />
            </LinearLayout>

            <Button
                    android:id="@+id/btnlistar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#6E4E9E"
                    android:onClick="listar"
                    android:text="Listar"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
