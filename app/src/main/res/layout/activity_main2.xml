<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/registro_background"
        android:fillViewport="true"
        tools:context=".MainActivity2">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="48dp"
            android:paddingEnd="20dp"
            android:paddingBottom="48dp">

        <TextView
                android:id="@+id/txtTituloListado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Listado de personas"
                android:textColor="#2F2A35"
                android:textSize="26sp"
                android:textStyle="bold" />

        <LinearLayout
                android:id="@+id/contenedorListado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@drawable/registro_card_background"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="18dp">

            <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true"
                    android:scrollbars="none">

                <TableLayout
                        android:id="@+id/tablaPersonas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="1,2">

                    <TableRow
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/tabla_header_background">

                        <TextView
                                android:layout_width="76dp"
                                android:layout_height="48dp"
                                android:gravity="center"
                                android:text="Id"
                                android:textColor="@android:color/white"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        <TextView
                                android:layout_width="140dp"
                                android:layout_height="48dp"
                                android:gravity="center"
                                android:text="Nombre"
                                android:textColor="@android:color/white"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        <TextView
                                android:layout_width="140dp"
                                android:layout_height="48dp"
                                android:gravity="center"
                                android:text="Apellido"
                                android:textColor="@android:color/white"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                    </TableRow>

                    <TableRow
                            android:id="@+id/filaPersonaVacia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                        <TextView
                                android:layout_width="76dp"
                                android:layout_height="56dp"
                                android:background="@drawable/tabla_cell_background"
                                android:gravity="center"
                                android:text="-"
                                android:textColor="#665C6B"
                                android:textSize="15sp"
                                android:id="@+id/tblistado" />

                        <TextView
                                android:id="@+id/celdaNombreVacia"
                                android:layout_width="140dp"
                                android:layout_height="56dp"
                                android:background="@drawable/tabla_cell_background"
                                android:gravity="center"
                                android:text="Sin registros"
                                android:textColor="#665C6B"
                                android:textSize="15sp" />

                        <TextView
                                android:id="@+id/celdaApellidoVacia"
                                android:layout_width="140dp"
                                android:layout_height="56dp"
                                android:background="@drawable/tabla_cell_background"
                                android:gravity="center"
                                android:text="-"
                                android:textColor="#665C6B"
                                android:textSize="15sp" />
                    </TableRow>
                </TableLayout>
            </HorizontalScrollView>

            <Button
                    android:id="@+id/btnVolverRegistro"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="18dp"
                    android:backgroundTint="#6E4E9E"
                    android:text="Volver al registro"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>